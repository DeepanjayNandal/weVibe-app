generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [postgis]
}

model matches {
  id                             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_a_id                      String?            @db.Uuid
  user_b_id                      String?            @db.Uuid
  created_at                     DateTime?          @default(now()) @db.Timestamp(6)
  status                         enum_match_status? @default(active)
  last_message_content           String?            @db.VarChar(255)
  last_message_at                DateTime?          @db.Timestamp(6)
  expires_at                     DateTime?          @db.Timestamp(6)
  message_count                  Int?               @default(0)
  user_a_decision                enum_decision?     @default(pending)
  user_b_decision                enum_decision?     @default(pending)
  users_matches_user_a_idTousers users?             @relation("matches_user_a_idTousers", fields: [user_a_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_matches_user_b_idTousers users?             @relation("matches_user_b_idTousers", fields: [user_b_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  messages                       messages[]
  user_reports                   user_reports[]

  @@index([user_a_id, last_message_at], map: "idx_matches_user_a")
  @@index([user_b_id, last_message_at], map: "idx_matches_user_b")
}

model messages {
  id         BigInt         @id @default(autoincrement())
  match_id   String?        @db.Uuid
  sender_id  String?        @db.Uuid
  content    String
  type       enum_msg_type? @default(text)
  created_at DateTime?      @default(now()) @db.Timestamp(6)
  read_at    DateTime?      @db.Timestamp(6)
  matches    matches?       @relation(fields: [match_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users?         @relation(fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([match_id, created_at], map: "idx_messages_match_id")
}

model profiles {
  user_id               String                    @id @db.Uuid

  // Basic identity — first_name and last_name are stored separately (display_name kept for internal use)
  first_name            String?                   @db.VarChar(100)
  last_name             String?                   @db.VarChar(100)
  display_name          String?                   @db.VarChar(100)
  nickname              String?                   @db.VarChar(50)
  birth_date            DateTime?                 @db.Date
  // gender: biological sex from onboarding ("Male", "Female", "Non-binary", "Prefer not to say")
  gender                String?                   @db.VarChar(50)
  sex                   enum_sex?
  // pronouns: free text e.g. "she/her", "he/him" — set via profile edit
  pronouns              String?                   @db.VarChar(50)
  // orientation: sexual orientation — set via profile edit
  orientation           String?                   @db.VarChar(50)
  // gender_identity: separate from gender — set via profile edit
  gender_identity       String?                   @db.VarChar(50)
  // visibility toggles — user controls what shows on their public profile
  show_sex              Boolean?                  @default(true)
  show_orientation      Boolean?                  @default(true)
  show_identity         Boolean?                  @default(true)
  show_personality_trait Boolean?                 @default(true)
  // ethnicity stored as JSON array — users can select multiple (e.g. ["White", "Asian"])
  ethnicity             Json?
  // birth_country: single-select country of origin — set via profile edit
  birth_country         String?                   @db.VarChar(100)

  // Height — unit determines which fields are used
  // imperial: height_ft + height_in | metric: height_cm
  height_unit           String?                   @db.VarChar(10)
  height_ft             Int?
  height_in             Int?
  height_cm             Int?

  // Location — stored as separate lat/lng floats (simpler than PostGIS for onboarding writes)
  // location_point is kept for matchmaking distance queries (PostGIS)
  latitude              Float?
  longitude             Float?
  location_point        Unsupported("geography(Point,4326)")?
  location_city         String?                   @db.VarChar(100)
  state                 String?                   @db.VarChar(100)   // exposed as location_state in API responses
  zip_code              String?                   @db.VarChar(20)    // exposed as location_zip in API responses

  // education: snake_case values e.g. "bachelors", "masters" — matches iOS EducationLevel rawValue
  education             String?                   @db.VarChar(100)
  // career_field: industry enum e.g. "Technology", "Healthcare" — collected during onboarding
  career_field          String?                   @db.VarChar(100)
  // job_title: free text e.g. "Software Engineer" — set via profile edit
  job_title             String?                   @db.VarChar(100)
  // school: free text e.g. "MIT" — set via profile edit
  school                String?                   @db.VarChar(100)
  // languages: JSON array of spoken languages e.g. ["English", "Spanish"] — collected during onboarding
  languages             Json?

  // Relationship goals — stored as a JSON array (e.g. ["short_term", "long_term"])
  // Replaces the single relationship_intent enum to allow multi-select (max 2)
  relationship_goals    Json?
  relationship_intent   enum_intent?              // kept for legacy/matchmaking use — do not remove

  personality_primary   String?                   @db.VarChar(100)
  personality_secondary String?                   @db.VarChar(100)

  // Lifestyle habits (all optional) — stored as plain strings to match exact iOS values
  lifestyle_drinks      String?                   @db.VarChar(20)
  lifestyle_smoking     String?                   @db.VarChar(20)
  lifestyle_workout     String?                   @db.VarChar(20)
  lifestyle_pets        String?                   @db.VarChar(20)
  lifestyle_children    String?                   @db.VarChar(20)
  lifestyle_sleep       String?                   @db.VarChar(20)
  // cannabis habit — same frequency values as drinks/smoking/workout
  lifestyle_cannabis    String?                   @db.VarChar(20)
  // pet detail fields — free text, only relevant when lifestyle_pets = "Have"
  pet_types             String?                   @db.VarChar(100)
  pets_name             String?                   @db.VarChar(100)

  // Lifestyle flexibility flags — user is okay if match has different habit
  is_drinks_flexible    Boolean?                  @default(false)
  is_smoking_flexible   Boolean?                  @default(false)
  is_workout_flexible   Boolean?                  @default(false)
  is_sleep_flexible     Boolean?                  @default(false)
  is_cannabis_flexible  Boolean?                  @default(false)
  is_kids_flexible      Boolean?                  @default(false)

  // Free-text bio, max 500 characters — enforced in application layer
  bio                   String?                   @db.VarChar(500)

  // Social handles — set via profile edit, iOS strips @ before sending
  instagram_handle      String?                   @db.VarChar(100)
  tiktok_handle         String?                   @db.VarChar(100)
  spotify_playlist_url  String?                   @db.VarChar(500)

  // Personality fields — set via profile edit
  love_language         String?                   @db.VarChar(50)
  zodiac_sign           String?                   @db.VarChar(20)
  // communication_style / conflict_style: enum or "" (empty = neutral/middle of slider)
  communication_style   String?                   @db.VarChar(50)
  conflict_style        String?                   @db.VarChar(50)
  // personality_type: MBTI result e.g. "Consul (ESFJ)" — set by Personality Test flow, read-only here
  personality_type      String?                   @db.VarChar(100)

  // Interests — JSON array, max 7 items
  interests             Json?
  // preferred_date_activities / would_not_do_activities — JSON arrays, max 3 items each
  preferred_date_activities   Json?
  would_not_do_activities     Json?

  // Prompts — JSON array of { question, answer }, max 4 items (3 preset + 1 custom)
  prompts               Json?
  photos                Json?
  social_integrations   Json?
  likes_received_count  Int?                      @default(0)

  // User preferences — moved here from users table for cleaner profile ownership
  // meet_preference: who the user wants to meet — stored as plain string to match iOS values ("Men", "Women", "Open to both")
  meet_preference       String?                   @db.VarChar(20)
  // Age preferences for matchmaking
  min_age_preference    Int?
  max_age_preference    Int?
  // Distance preference in miles (not km — matches what the iOS app sends)
  distance_preference_miles Int?

  users                 users                     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([location_point], map: "idx_profiles_location", type: Gist)
  @@index([gender, personality_primary], map: "idx_profiles_personality")
}

model speed_dating_sessions {
  id                                           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_a_id                                    String?   @db.Uuid
  user_b_id                                    String?   @db.Uuid
  started_at                                   DateTime? @default(now()) @db.Timestamp(6)
  expires_at                                   DateTime? @db.Timestamp(6)
  status                                       String?   @db.VarChar(50)
  user_a_decision                              enum_decision? @default(pending)
  user_b_decision                              enum_decision? @default(pending)
  users_speed_dating_sessions_user_a_idTousers users?    @relation("speed_dating_sessions_user_a_idTousers", fields: [user_a_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_speed_dating_sessions_user_b_idTousers users?    @relation("speed_dating_sessions_user_b_idTousers", fields: [user_b_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  speed_dating_messages                        speed_dating_messages[]
}

model speed_dating_messages {
  id                    BigInt                 @id @default(autoincrement())
  session_id            String?                @db.Uuid
  sender_id             String?                @db.Uuid
  content               String
  type                  enum_msg_type?         @default(text)
  created_at            DateTime?              @default(now()) @db.Timestamp(6)
  read_at               DateTime?              @db.Timestamp(6)
  speed_dating_sessions speed_dating_sessions? @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                 users?                 @relation(fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([session_id, created_at], map: "idx_sd_messages_session_id")
}

model photo_upload_pending {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  photo_id     String   @unique @db.VarChar(100)
  storage_path String   @db.VarChar(500)
  user_id      String   @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamp(6)
  users        users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at], map: "idx_photo_upload_pending_created_at")
}

model matching_queue {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id   String   @unique @db.Uuid
  joined_at DateTime @default(now()) @db.Timestamp(6)
  users     users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([joined_at], map: "idx_matching_queue_joined_at")
}

model user_blocks {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blocker_user_id  String   @db.Uuid
  blocked_user_id  String   @db.Uuid
  reason           String?  @db.VarChar(255)
  created_at       DateTime @default(now()) @db.Timestamp(6)
  users_user_blocks_blocked users @relation("user_blocks_blocked", fields: [blocked_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_user_blocks_blocker users @relation("user_blocks_blocker", fields: [blocker_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([blocker_user_id, blocked_user_id], map: "uq_user_blocks_pair")
  @@index([blocker_user_id], map: "idx_user_blocks_blocker")
  @@index([blocked_user_id], map: "idx_user_blocks_blocked")
}

model users {
  id                                                           String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                                                        String                  @unique @db.VarChar(255)
  firebase_uid                                                 String                  @unique @db.VarChar(255)
  auth_provider                                                enum_auth_provider?     @default(email)
  phone                                                        String?                 @unique @db.VarChar(50)
  password_hash                                                String?                 @db.VarChar(255)
  created_at                                                   DateTime?               @default(now()) @db.Timestamp(6)
  last_active_at                                               DateTime?               @db.Timestamp(6)
  is_banned                                                    Boolean?                @default(false)
  // deleted_at: set when user requests account deletion (soft delete).
  // NULL = active user. Non-null = deleted, blocked from login.
  // After 30 days the purge job hard-deletes the row via CASCADE.
  // If the user logs back in within 30 days, deleted_at is cleared (reactivation).
  deleted_at                                                   DateTime?               @db.Timestamp(6)
  // onboarding_complete: set to true after user submits the onboarding survey (POST /api/v1/users/profile)
  // iOS uses this to decide whether to route to onboarding or the main app after login
  onboarding_complete                                          Boolean?                @default(false)
  is_registration_complete                                     Boolean?                @default(false)
  is_personality_test_complete                                 Boolean?                @default(false)
  current_status                                               enum_user_status?       @default(offline)
  search_radius_km                                             Int?                    @default(50)
  search_age_min                                               Int?                    @default(18)
  search_age_max                                               Int?                    @default(35)
  search_gender                                                enum_meet_gender?       @default(both)
  preferences                                                  Json?
  matches_matches_user_a_idTousers                             matches[]               @relation("matches_user_a_idTousers")
  matches_matches_user_b_idTousers                             matches[]               @relation("matches_user_b_idTousers")
  messages                                                     messages[]
  matching_queue                                               matching_queue?
  profiles                                                     profiles?
  speed_dating_messages                                        speed_dating_messages[]
  speed_dating_sessions_speed_dating_sessions_user_a_idTousers speed_dating_sessions[] @relation("speed_dating_sessions_user_a_idTousers")
  speed_dating_sessions_speed_dating_sessions_user_b_idTousers speed_dating_sessions[] @relation("speed_dating_sessions_user_b_idTousers")
  user_blocks_user_blocks_blocked                              user_blocks[]          @relation("user_blocks_blocked")
  user_blocks_user_blocks_blocker                              user_blocks[]          @relation("user_blocks_blocker")
  user_reports_user_reports_reported                           user_reports[]         @relation("user_reports_reported")
  user_reports_user_reports_reporter                           user_reports[]         @relation("user_reports_reporter")
  photo_upload_pending                                         photo_upload_pending[]
}

model user_reports {
  id                                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporter_user_id                  String    @db.Uuid
  reported_user_id                  String    @db.Uuid
  match_id                          String?   @db.Uuid
  reason                            String    @db.VarChar(255)
  details                           String?   @db.VarChar(1000)
  created_at                        DateTime  @default(now()) @db.Timestamp(6)
  matches                           matches?  @relation(fields: [match_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  users_user_reports_reported       users     @relation("user_reports_reported", fields: [reported_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_user_reports_reporter       users     @relation("user_reports_reporter", fields: [reporter_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([reporter_user_id], map: "idx_user_reports_reporter")
  @@index([reported_user_id], map: "idx_user_reports_reported")
  @@index([match_id], map: "idx_user_reports_match")
}

enum enum_match_status {
  active
  unmatched
  reported
  trial
  waiting_decision
  expired
}

enum enum_msg_type {
  text
  image
  audio
  system
}

enum enum_auth_provider {
  google
  apple
  facebook
  twitter
  email
}

enum enum_user_status {
  active
  offline
  in_speed_date
  banned
}

enum enum_decision {
  pending
  yes
  no
}

enum enum_sex {
  male
  female
}

enum enum_meet_gender {
  men
  women
  both
}

enum enum_intent {
  short_term
  long_term
  marriage
  figuring_out
}

enum enum_education {
  high_school
  in_college
  bachelors
  masters
  phd
  other
}

enum enum_frequency {
  never
  sometimes
  often
}

enum enum_preference_level {
  dont_want
  unsure
  want
  have
}

enum enum_sleep_schedule {
  night_owl
  early_bird
  flexible
}

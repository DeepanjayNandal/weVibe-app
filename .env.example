# This is a template for your local environment variables
# Copy this file to .env and update the values
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASS=password
DB_NAME=wevibe_dev

# Prisma runtime connection string (preferred)
DATABASE_URL=postgresql://admin:password@localhost:5432/wevibe_dev

# API
PORT=3000

# Auth provider mode: mock | firebase
AUTH_PROVIDER_MODE=mock

# Mock idToken format used by local testing:
# mock:<provider>:<uid>:<email>
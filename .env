# This is a template for your local environment variables
# Copy this file to .env and update the values
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASS=password
DB_NAME=wevibe_dev

# Prisma runtime connection string (preferred)
DATABASE_URL=postgresql://admin:password@localhost:5432/wevibe_dev

# API
PORT=3000

# Auth provider mode: mock | firebase
# Use 'mock' for local development (no Firebase credentials needed)
# Use 'firebase' for staging/production (requires credentials below)
AUTH_PROVIDER_MODE=mock

# Mock idToken format used by local testing:
# mock:<provider>:<uid>:<email>
# Example: mock:google:uid123:user@example.com

# ---------------------------------------------------------------------------
# Firebase credentials — only required when AUTH_PROVIDER_MODE=firebase
# ---------------------------------------------------------------------------

# Your Firebase project ID (found in Firebase Console > Project Settings)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Path to your Firebase service account JSON file (downloaded from Firebase Console)
# Firebase Console > Project Settings > Service Accounts > Generate new private key
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# This is a template for your local environment variables
# Copy this file to .env and update the values
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASS=password
DB_NAME=wevibe_dev

# Prisma runtime connection string (preferred)
DATABASE_URL=postgresql://admin:password@localhost:5432/wevibe_dev

# API
PORT=3000

# Auth provider mode: mock | firebase
# Use 'mock' for local development (no Firebase credentials needed)
# Use 'firebase' for staging/production (requires credentials below)
AUTH_PROVIDER_MODE=mock

# Mock idToken format used by local testing:
# mock:<provider>:<uid>:<email>
# Example: mock:google:uid123:user@example.com

# ---------------------------------------------------------------------------
# Firebase credentials — only required when AUTH_PROVIDER_MODE=firebase
# Two environments exist: dev and prod. Switch by swapping which block is active.
# Place service account JSON files in backend/secrets/ (gitignored — never commit them)
# ---------------------------------------------------------------------------

# --- DEV (active by default) ---
FIREBASE_PROJECT_ID=wevibe-dev
GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-service-account-dev.json
FIREBASE_STORAGE_BUCKET=wevibe-dev.firebasestorage.app

# --- PROD (comment out DEV block above and uncomment this block to switch) ---
# FIREBASE_PROJECT_ID=your-prod-project-id
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-service-account-prod.json

# --- SOCKET IO REDIS URL
UPSTASH_REDIS_URL="rediss://default:AZtFAAIncDExYjc0MjIyY2E3M2U0NDk1OWZiMzc1NTQ5ZDhmNWNkNXAxMzk3NDk@normal-flamingo-39749.upstash.io:6379"
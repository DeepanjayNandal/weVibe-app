    "@types/jest": "^29.5.12",
    "@types/node": "^22.13.1",
    "@types/pg": "^8.11.0",
    "jest": "^29.7.0",
    "prisma": "6.3.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",

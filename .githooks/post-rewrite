#!/bin/bash
# Regenerate Xcode project if project.yml changed after a rebase

if git diff HEAD@{1} --name-only 2>/dev/null | grep -q "frontend/iOS/project.yml"; then
  echo "[xcodegen] project.yml changed — regenerating Xcode project..."
  (cd "$(git rev-parse --show-toplevel)/frontend/iOS" && xcodegen generate)
fi

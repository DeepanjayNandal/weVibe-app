default_platform(:ios)

platform :ios do

  desc "Sync development certs for local dev"
  lane :sync_dev do
    match(type: "development")
  end

  desc "Add new device and refresh dev profile"
  lane :add_device do
    register_devices(
      devices_file: "fastlane/devices.txt",
      api_key_path: "fastlane/api_key.json"
    )
    match(type: "development", force_for_new_devices: true)
  end

  desc "Push beta build to TestFlight"
  lane :beta do
    match(type: "appstore")
    build_app(
      scheme: "WeVibe",
      configuration: "Release",
      export_method: "app-store"
    )
    upload_to_testflight(
      api_key_path: "fastlane/api_key.json",
      app_identifier: "com.wevibe1.app",
      skip_waiting_for_build_processing: true
    )
  end

end
